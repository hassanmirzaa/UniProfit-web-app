# Supabase (required for auth and save/load scenarios)
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# If the URL is wrong or you are offline, edge middleware can spam logs while retrying auth.
# Set to true to skip Supabase in middleware entirely (browser auth still runs).
# SUPABASE_SKIP_MIDDLEWARE=true

# Gemini API (optional – for AI suggestions)
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# PSX Terminal API (optional – defaults to https://psxterminal.com/api)
# Override if you use a proxy (e.g. Laravel /psx)
NEXT_PUBLIC_PSX_API_URL=https://psxterminal.com/api

# ── Ads Monetization (Phase 1) ────────────────────────────────────────────────
# Google AdSense — get publisher ID from adsense.google.com after approval
# Ad unit slot IDs are created per page in the AdSense dashboard
# Defaults to ca-pub-6520119728614881 in code if unset; override per environment if needed
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-6520119728614881
NEXT_PUBLIC_ADSENSE_SLOT_ECOMMERCE=
NEXT_PUBLIC_ADSENSE_SLOT_ANALYTICS=
NEXT_PUBLIC_ADSENSE_SLOT_LOGIN=

# Affiliate partner links — replace with your referral URLs after signing up
NEXT_PUBLIC_AFFILIATE_LOGISTICS_URL=https://postex.pk
NEXT_PUBLIC_AFFILIATE_BROKER_URL=https://ahsec.com.pk
